@{
    ViewBag.Title = "Login";

    string role = ViewBag.Role != null ? ViewBag.Role.ToString() : "Candidate";

    bool isEmployer = role == "Employer";

    if (isEmployer)
    {
        Layout = "~/Views/Shared/_EmployerPublicLayout.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }

    string roleText = isEmployer ? "Employer" : "Job Candidate";
    string roleIcon = isEmployer ? "fa-building" : "fa-user";
}
<div class="auth-page">

    <div class="auth-card">

        <div class="login-role-badge @(isEmployer ? "employer" : "candidate")">
            <i class="fa @roleIcon"></i>
            <span>@roleText</span>
        </div>

        <h2>Login</h2>

        @if (ViewBag.Error != null)
        {
            <div class="auth-alert">
                @ViewBag.Error
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="auth-alert success">
                @TempData["Success"]
            </div>
        }

        <form method="post" action="@Url.Action("Login", "Account")">

            <input type="hidden" name="role" value="@role" />

            <div class="auth-group">
                <input type="text"
                       name="userName"
                       placeholder="Email / Username"
                       autocomplete="username" />
            </div>

            <div class="auth-group password-group">
                <input type="password"
                       name="password"
                       id="passwordInput"
                       placeholder="Password"
                       autocomplete="current-password" />

                <button type="button" class="toggle-password" onclick="togglePassword()">
                    <i class="fa fa-eye-slash" id="eyeIcon"></i>
                </button>
            </div>

            <div class="auth-extra">
                <a href="@Url.Action("ForgotPassword", "Account", new { role = isEmployer ? "Employer" : "Candidate" })">
                    Forgot password?
                </a>
            </div>

            <button type="submit" class="auth-submit">
                Login
            </button>

        </form>

        <div class="auth-bottom">
            <span>Don't have an account?</span>

            @if (isEmployer)
            {
                <a href="@Url.Action("RegisterEmployer", "Account")">
                    Register as Employer
                </a>
            }
            else
            {
                <a href="@Url.Action("RegisterCandidate", "Account")">
                    Register as Candidate
                </a>
            }
        </div>

        <div class="switch-role">
            @if (isEmployer)
            {
                <a href="@Url.Action("Login", "Account", new { role = "Candidate" })">
                    Switch to Candidate Login
                </a>
            }
            else
            {
                <a href="@Url.Action("Login", "Account", new { role = "Employer" })">
                    Switch to Employer Login
                </a>
            }
        </div>

    </div>

</div>

<script>
    function togglePassword() {
        var input = document.getElementById("passwordInput");
        var icon = document.getElementById("eyeIcon");

        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        } else {
            input.type = "password";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        }
    }
</script>