@{
    ViewBag.Title = "Add CV Template";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (ViewBag.Error != null)
{
    <div class="auth-error">
        @ViewBag.Error
    </div>
}

<form method="post"
      action="@Url.Action("Create", "AdminCVTemplates")"
      enctype="multipart/form-data"
      class="admin-cv-form">

    <div class="form-group">
        <label>CV Template Name</label>
        <input type="text" name="templateName" placeholder="Example: Professional Blue CV" />
    </div>

    <div class="form-group">
        <label>Template Category</label>
        <select name="category">
            <option value="Professional">Professional</option>
            <option value="Modern">Modern</option>
            <option value="Student">Student</option>
            <option value="Simple">Simple</option>
        </select>
    </div>

    <div class="form-group">
        <label>Preview Image</label>
        <input type="file"
               name="previewFile"
               id="previewFile"
               accept="image/*"
               onchange="showSelectedImage(this)" />

        <small>Choose a JPG, PNG, JPEG, or WEBP image to preview the CV template.</small>

        <div id="selectedImageBox" class="admin-selected-file-box" style="display:none;">
            <p><strong>Selected image:</strong> <span id="selectedImageName"></span></p>
            <img id="selectedImagePreview" class="admin-selected-image-preview" />
        </div>
    </div>

    <div class="form-group">
        <label>Word CV Template File</label>
        <input type="file"
               name="cvFile"
               id="cvFile"
               accept=".docx"
               onchange="showSelectedDocx(this)" />

        <small>Only .docx files are allowed. Candidates will download this file and edit it in Microsoft Word.</small>

        <div id="selectedDocxBox" class="admin-selected-file-box" style="display:none;">
            <p><strong>Selected Word file:</strong> <span id="selectedDocxName"></span></p>
            <p><strong>File size:</strong> <span id="selectedDocxSize"></span></p>
        </div>
    </div>

    <div class="form-group">
        <label>Description</label>
        <textarea name="description" placeholder="Short description of this CV template"></textarea>
    </div>

    <div class="form-check">
        <input type="checkbox" name="isActive" value="true" checked />
        <label>Show this CV template</label>
    </div>

    <div class="form-actions">
        <button type="submit" class="admin-submit-btn">
            Save CV Template
        </button>

        <a href="@Url.Action("Index", "AdminCVTemplates")" class="admin-back-btn">
            Back
        </a>
    </div>

</form>

<script>
    function showSelectedImage(input) {
        var box = document.getElementById("selectedImageBox");
        var name = document.getElementById("selectedImageName");
        var preview = document.getElementById("selectedImagePreview");

        if (input.files && input.files[0]) {
            var file = input.files[0];

            name.innerText = file.name;
            preview.src = URL.createObjectURL(file);
            box.style.display = "block";
        }
    }

    function showSelectedDocx(input) {
        var box = document.getElementById("selectedDocxBox");
        var name = document.getElementById("selectedDocxName");
        var size = document.getElementById("selectedDocxSize");

        if (input.files && input.files[0]) {
            var file = input.files[0];

            name.innerText = file.name;
            size.innerText = formatFileSize(file.size);
            box.style.display = "block";
        }
    }

    function formatFileSize(bytes) {
        if (bytes < 1024) {
            return bytes + " B";
        }

        if (bytes < 1024 * 1024) {
            return (bytes / 1024).toFixed(1) + " KB";
        }

        return (bytes / (1024 * 1024)).toFixed(1) + " MB";
    }
</script>