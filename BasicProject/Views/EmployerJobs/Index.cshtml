@model IEnumerable<BasicProject.Models.Job>

@{
    ViewBag.Title = "Manage Job Posts";
    Layout = "~/Views/Shared/_EmployerLayout.cshtml";

    string companyStatus = ViewBag.CompanyStatus != null ? ViewBag.CompanyStatus.ToString() : "";
    bool canPostJob = ViewBag.CanPostJob != null && ViewBag.CanPostJob == true;
}

<div class="employer-jobs-page">

    <div class="employer-page-head">
        <div>
            <h1>Manage Job Posts</h1>
        </div>

        @if (canPostJob)
        {
            <a href="@Url.Action("Create", "EmployerJobs")" class="employer-add-btn">
                <i class="fa fa-plus"></i> Post New Job
            </a>
        }
        else
        {
            <a href="javascript:void(0)"
               class="employer-add-btn disabled-action"
               title="Your company has not been approved by admin, so you cannot post jobs yet.">
                <i class="fa fa-lock"></i> Cannot Post Yet
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="auth-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="auth-error">
            @TempData["Error"]
        </div>
    }

    @if (companyStatus == "Pending")
    {
        <div class="auth-error">
            Your company is waiting for admin approval. You cannot post jobs yet.
        </div>
    }
    else if (companyStatus == "Rejected")
    {
        <div class="auth-error">
            Your company has been rejected by admin. Please update your company information.
        </div>
    }
    else if (companyStatus == "Approved")
    {
        <div class="auth-success">
            Your company has been approved. New job posts still need admin approval before being visible to candidates.
        </div>
    }

    <div class="employer-job-list">

        @if (Model != null && Model.Any())
        {
            foreach (var job in Model)
            {
                <div class="employer-job-card">

                    <div class="employer-job-logo">
                        @if (job.Company != null && !string.IsNullOrEmpty(job.Company.Logo))
                        {
                            <img src="@Url.Content(job.Company.Logo)" alt="@job.Company.CompanyName" />
                        }
                        else
                        {
                            <span>
                                @(job.Company != null && !string.IsNullOrEmpty(job.Company.CompanyName)
                                    ? job.Company.CompanyName.Substring(0, 1)
                                    : "J")
                            </span>
                        }
                    </div>

                    <div class="employer-job-info">

                        <div class="employer-job-title-row">
                            <h3 title="@job.Title">@job.Title</h3>

                            @if (job.Status == "Approved")
                            {
                                <span class="employer-job-status status-approved">
                                    Approved
                                </span>
                            }
                            else if (job.Status == "Rejected")
                            {
                                <span class="employer-job-status status-rejected">
                                    Rejected
                                </span>
                            }
                            else if (job.Status == "Closed")
                            {
                                <span class="employer-job-status status-closed">
                                    Closed
                                </span>
                            }
                            else
                            {
                                <span class="employer-job-status status-pending">
                                    Pending
                                </span>
                            }
                        </div>

                        <p class="employer-company-name">
                            @(job.Company != null ? job.Company.CompanyName : "Updating")
                        </p>

                        <div class="employer-job-meta">
                            <span>
                                <i class="fa fa-map-marker"></i>
                                @(string.IsNullOrEmpty(job.Location) ? "Updating" : job.Location)
                            </span>

                            <span>
                                <i class="fa fa-money"></i>
                                @(job.Salary.HasValue ? job.Salary.Value.ToString("N0") + " USD" : "Negotiable")
                            </span>

                            <span>
                                <i class="fa fa-calendar"></i>
                                @(job.CreatedAt.HasValue ? job.CreatedAt.Value.ToString("dd/MM/yyyy") : "Unknown")
                            </span>
                        </div>

                        @if (job.Status == "Pending")
                        {
                            <p class="employer-job-note">
                                This job post is waiting for admin approval and is not visible to candidates yet.
                            </p>
                        }
                        else if (job.Status == "Rejected")
                        {
                            <p class="employer-job-note rejected">
                                This job post has been rejected. You can edit it and submit it for review again.
                            </p>
                        }
                        else if (job.Status == "Closed")
                        {
                            <p class="employer-job-note closed">
                                This job post has been closed and is no longer visible to candidates.
                            </p>
                        }

                    </div>

                    <div class="employer-job-actions">

                        <a href="@Url.Action("ByJob", "EmployerApplications", new { id = job.JobID })" class="btn-view-cv">
                            <i class="fa fa-file-text"></i> View CVs
                        </a>

                        <a href="@Url.Action("Edit", "EmployerJobs", new { id = job.JobID })" class="btn-edit-job">
                            <i class="fa fa-pencil"></i> Edit
                        </a>

                        <form method="post"
                              action="@Url.Action("Delete", "EmployerJobs", new { id = job.JobID })"
                              onsubmit="return confirm('Are you sure you want to delete this job post?');">
                            <button type="submit" class="btn-delete-job">
                                <i class="fa fa-trash"></i> Delete
                            </button>
                        </form>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="employer-empty">
                <h3>No job posts yet</h3>
                <p>Post your first job for your company.</p>

                @if (canPostJob)
                {
                    <a href="@Url.Action("Create", "EmployerJobs")">
                        Post New Job
                    </a>
                }
                else
                {
                    <a href="javascript:void(0)" class="disabled-action">
                        Company Not Approved Yet
                    </a>
                }
            </div>
        }

    </div>

</div>