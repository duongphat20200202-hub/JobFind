@model BasicProject.Models.Job

@{
    ViewBag.Title = "Edit Job Post";
    Layout = "~/Views/Shared/_EmployerLayout.cshtml";
}

<h1 class="employer-title">Edit Job Post</h1>

@if (ViewBag.Error != null)
{
    <div class="auth-error">@ViewBag.Error</div>
}

<form method="post" action="@Url.Action("Edit", "EmployerJobs")" class="employer-form">

    <input type="hidden" name="id" value="@Model.JobID" />

    <div class="form-group">
        <label>Job Title</label>
        <input type="text"
               name="title"
               value="@Model.Title"
               placeholder="Example: Junior Frontend Developer, Senior Sales Executive..." />
        <small>Use clear keywords such as Junior, Senior, Frontend, Sales, Accountant to improve search results.</small>
    </div>

    <div class="form-group">
        <label>Job Category</label>
        <select name="categoryId">
            <option value="">-- Select a category --</option>

            @foreach (var cate in ViewBag.Categories)
            {
                <option value="@cate.CategoryID" @(Model.CategoryID == cate.CategoryID ? "selected" : "")>
                    @cate.CategoryName
                </option>
            }
        </select>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Salary</label>
            <input type="number"
                   name="salary"
                   min="0"
                   value="@(Model.Salary.HasValue ? Model.Salary.Value.ToString("0") : "")"
                   placeholder="Example: 1000" />
            <small>Leave empty or enter 0 for Negotiable.</small>
        </div>

        <div class="form-group">
            <label>Location</label>
            <select name="location">
                <option value="">-- Select location --</option>
                <option value="Hồ Chí Minh" @(Model.Location == "Hồ Chí Minh" ? "selected" : "")>Hồ Chí Minh</option>
                <option value="Hà Nội" @(Model.Location == "Hà Nội" ? "selected" : "")>Hà Nội</option>
                <option value="Đà Nẵng" @(Model.Location == "Đà Nẵng" ? "selected" : "")>Đà Nẵng</option>
                <option value="Đồng Nai" @(Model.Location == "Đồng Nai" ? "selected" : "")>Đồng Nai</option>
                <option value="Bình Dương" @(Model.Location == "Bình Dương" ? "selected" : "")>Bình Dương</option>
                <option value="Hải Phòng" @(Model.Location == "Hải Phòng" ? "selected" : "")>Hải Phòng</option>
                <option value="Remote" @(Model.Location == "Remote" ? "selected" : "")>Remote</option>
            </select>
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Job Type</label>
            <select name="jobType">
                <option value="">-- Select job type --</option>
                <option value="Full-time" @(Model.JobType == "Full-time" ? "selected" : "")>Full-time</option>
                <option value="Part-time" @(Model.JobType == "Part-time" ? "selected" : "")>Part-time</option>
                <option value="Internship" @(Model.JobType == "Internship" ? "selected" : "")>Internship</option>
                <option value="Remote" @(Model.JobType == "Remote" ? "selected" : "")>Remote</option>
                <option value="Hybrid" @(Model.JobType == "Hybrid" ? "selected" : "")>Hybrid</option>
                <option value="Freelance" @(Model.JobType == "Freelance" ? "selected" : "")>Freelance</option>
            </select>
        </div>

        <div class="form-group">
            <label>Experience / Level</label>
            <select name="experience">
                <option value="">-- Select experience --</option>
                <option value="No experience required" @(Model.Experience == "No experience required" ? "selected" : "")>No experience required</option>
                <option value="Intern" @(Model.Experience == "Intern" ? "selected" : "")>Intern</option>
                <option value="Fresher" @(Model.Experience == "Fresher" ? "selected" : "")>Fresher</option>
                <option value="Junior - 1 year" @(Model.Experience == "Junior - 1 year" ? "selected" : "")>Junior - 1 year</option>
                <option value="Junior - 2 years" @(Model.Experience == "Junior - 2 years" ? "selected" : "")>Junior - 2 years</option>
                <option value="Senior - 3 years" @(Model.Experience == "Senior - 3 years" ? "selected" : "")>Senior - 3 years</option>
                <option value="Senior - 5 years" @(Model.Experience == "Senior - 5 years" ? "selected" : "")>Senior - 5 years</option>
            </select>
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Application Deadline</label>
            <input type="date"
                   name="deadline"
                   min="@DateTime.Now.ToString("yyyy-MM-dd")"
                   value="@(Model.Deadline.HasValue ? Model.Deadline.Value.ToString("yyyy-MM-dd") : "")" />
            <small>The deadline cannot be earlier than today.</small>
        </div>

        <div class="form-group">
            <label>Hiring Quantity</label>
            <input type="number"
                   name="hiringQuantity"
                   min="1"
                   value="@(Model.HiringQuantity <= 0 ? 1 : Model.HiringQuantity)"
                   placeholder="Example: 3" />
            <small>
                Current remaining slots:
                <strong>@Model.RemainingSlots</strong>.
                Hiring quantity cannot be smaller than accepted candidates.
            </small>
        </div>
    </div>

    <div class="form-group">
        <label>Job Description</label>
        <textarea name="description"
                  placeholder="Describe the main tasks of this position.">@Model.Description</textarea>
        <small>Add important keywords naturally. These keywords help Search in description work better.</small>
    </div>

    <div class="form-group">
        <label>Requirements</label>
        <textarea name="requirement"
                  placeholder="Example: Junior level, 1 year experience, good communication, teamwork...">@Model.Requirement</textarea>
    </div>

    <div class="form-group">
        <label>Benefits</label>
        <textarea name="benefit"
                  placeholder="Example: Competitive salary, training, bonus, insurance...">@Model.Benefit</textarea>
    </div>

    <div class="form-actions">
        <button type="submit" class="auth-btn">
            Save Changes
        </button>

        <a href="@Url.Action("Index", "EmployerJobs")" class="btn-back">
            Back
        </a>
    </div>

</form>